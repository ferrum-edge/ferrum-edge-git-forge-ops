# Ferrum Edge GitForgeOps — Environment Variables
# For running gitforgeops commands locally.
# In CI, set these as GitHub repo secrets/variables instead.

# Required (secrets in CI)
FERRUM_GATEWAY_URL=https://your-gateway:9000
FERRUM_ADMIN_JWT_SECRET=your-32-char-minimum-jwt-secret-here

# TLS (optional — omit for public CA)
# FERRUM_GATEWAY_CA_CERT=<base64-encoded PEM>
# FERRUM_GATEWAY_CLIENT_CERT=<base64-encoded PEM>
# FERRUM_GATEWAY_CLIENT_KEY=<base64-encoded PEM>

# Namespace filter (omit to process all namespaces in resources/)
# FERRUM_NAMESPACE=ferrum

# Gateway mode: api (push via Admin API) or file (assemble flat YAML)
FERRUM_GATEWAY_MODE=api

# Overlay directory (e.g. staging, production)
# FERRUM_OVERLAY=

# Path to ferrum-edge binary (auto-detected on $PATH if unset)
FERRUM_EDGE_BINARY_PATH=ferrum-edge

# Apply strategy: incremental (CRUD) or full_replace (POST /restore)
# FERRUM_APPLY_STRATEGY=incremental

# File mode output path
# FERRUM_FILE_OUTPUT_PATH=./assembled/resources.yaml

# Skip TLS verification (dev only!)
# FERRUM_TLS_NO_VERIFY=false

# HTTP timeouts for admin-API calls. Raise request timeout for very large
# /backup responses or slow /restore commits. Raise connect timeout if
# the admin API is behind a slow load balancer.
# FERRUM_GATEWAY_CONNECT_TIMEOUT_SECS=10
# FERRUM_GATEWAY_REQUEST_TIMEOUT_SECS=60

# HTTP timeouts for the GitHub API call used by `gitforgeops review --pr N`.
# Defaults are appropriate for GitHub's public API; unlikely to need tuning.
# FERRUM_GITHUB_CONNECT_TIMEOUT_SECS=10
# FERRUM_GITHUB_REQUEST_TIMEOUT_SECS=30
