# Ferrum Edge GitForgeOps — Environment Variables
# For running gitforgeops commands locally.
# In CI, these come from GitHub Environment Secrets (scoped per env) and
# GitHub Environment Variables. See .gitforgeops/config.yaml for logical
# environment definitions.

# --- Environment selection ----------------------------------------------------

# Name of the environment declared in .gitforgeops/config.yaml. When set, this
# also picks the overlay, apply_strategy, and ownership mode from that file.
# Can also be passed as `gitforgeops --env <name> <command>`.
# FERRUM_ENV=staging

# --- Gateway connection (per-environment in CI) ------------------------------

FERRUM_GATEWAY_URL=https://your-gateway:9000
FERRUM_ADMIN_JWT_SECRET=your-32-char-minimum-jwt-secret-here

# TLS (optional — omit for public CA)
# FERRUM_GATEWAY_CA_CERT=<base64-encoded PEM>
# FERRUM_GATEWAY_CLIENT_CERT=<base64-encoded PEM>
# FERRUM_GATEWAY_CLIENT_KEY=<base64-encoded PEM>

# Namespace filter (overrides repo config; omit to process all namespaces).
# FERRUM_NAMESPACE=ferrum

# Gateway mode: api (push via Admin API) or file (assemble flat YAML)
FERRUM_GATEWAY_MODE=api

# Overlay directory (legacy; prefer .gitforgeops/config.yaml + FERRUM_ENV).
# FERRUM_OVERLAY=

# Apply strategy: incremental (CRUD) or full_replace (POST /restore)
# Incompatible with ownership.mode: shared — will error at startup.
# FERRUM_APPLY_STRATEGY=incremental

# Path to ferrum-edge binary (auto-detected on $PATH if unset)
FERRUM_EDGE_BINARY_PATH=ferrum-edge

# File mode output path
# FERRUM_FILE_OUTPUT_PATH=./assembled/resources.yaml

# Skip TLS verification (dev only!)
# FERRUM_TLS_NO_VERIFY=false

# --- Credential broker (in-GitHub) -------------------------------------------

# Token with repo `Secrets: write` + `Environments: write` permission, used to
# allocate or rotate consumer credentials. Prefer a short-lived GitHub App
# installation token over a PAT. Without this set, allocation/rotation fails.
# FERRUM_GH_PROVISIONER_TOKEN=

# Merged JSON object of FERRUM_CREDS_BUNDLE* env secret values. Produced by the
# workflow "Load credential bundles" step — do not set manually in CI. Locally,
# you can provide a JSON object for testing: {"FERRUM_CREDS_BUNDLE": {"slot":"v"}}
# FERRUM_CREDS_JSON=

# --- GitHub API (auto-populated in Actions) -----------------------------------

# Read-only token used to check PR override labels/permissions and post review
# comments. Provided automatically by `${{ secrets.GITHUB_TOKEN }}` in CI.
# GITHUB_TOKEN=
# GITHUB_REPOSITORY=owner/repo
